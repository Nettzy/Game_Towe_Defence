function scr_textos(){
	switch npc_nome
	{
		case "Primeiro texto":
			texto[0] = "Então vc que é o novo pobre coitado que foi contratado para a defesa né?";
			texto[1] = "Eu sabia! Olha eu sou a melhor no que faço, e oq eu faço é melhorar armas.";
			texto[2] = "Que tal melhorarmos essa belezinha, óbvio pelo preço certo.";
		break;
	}
}